local Player = game:Players.LocalPlayer
local VirtualInput = game:GetService("VirtualInputManager")

-- Cleanup function to prevent UI stacking if you re-run the script
local function CleanUI()
    local oldQ = game:GetService("CoreGui"):FindFirstChild("VoidQ")
    local oldT = game:GetService("CoreGui"):FindFirstChild("VoidT")
    if oldQ then oldQ:Destroy() end
    if oldT then oldT:Destroy() end
end
CleanUI()

-- Q Button (Grandfather Time)
local ScreenGuiQ = Instance.new("ScreenGui")
ScreenGuiQ.Name = "VoidQ"
ScreenGuiQ.Parent = game:GetService("CoreGui") or Player:WaitForChild("PlayerGui")
ScreenGuiQ.ResetOnSpawn = false

local QButton = Instance.new("TextButton")
QButton.Parent = ScreenGuiQ
QButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
QButton.Position = UDim2.new(1, -500, 0.7, 0) -- Side-by-side position
QButton.Size = UDim2.new(0, 70, 0, 70)
QButton.Text = "Q"
QButton.TextColor3 = Color3.fromRGB(255, 0, 255)
QButton.TextSize = 40
QButton.Font = Enum.Font.SpecialElite
Instance.new("UICorner", QButton).CornerRadius = UDim.new(0, 10)

QButton.MouseButton1Click:Connect(function()
    task.spawn(function()
        if GrandfatherTime then
            GrandfatherTime()
        else
            VirtualInput:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
        end
    end)
end)

