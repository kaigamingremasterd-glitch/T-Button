-- Q button
local ScreenGuiQ = Instance.new("ScreenGui")
local QButton = Instance.new("TextButton")
local UICornerQ = Instance.new("UICorner")

ScreenGuiQ.Name = "VoidMobileUI"
ScreenGuiQ.Parent = game:GetService("CoreGui") or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
ScreenGuiQ.ResetOnSpawn = false

QButton.Name = "QTrigger"
QButton.Parent = ScreenGuiQ
QButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
QButton.Position = UDim2.new(1, -500, 0.7, 0) -- Adjusted for screen visibility
QButton.Size = UDim2.new(0, 70, 0, 70)
QButton.Font = Enum.Font.SpecialElite
QButton.Text = "Q"
QButton.TextColor3 = Color3.fromRGB(255, 0, 255)
QButton.TextSize = 40

UICornerQ.CornerRadius = UDim.new(0, 10)
UICornerQ.Parent = QButton

QButton.MouseButton1Click:Connect(function()
    task.spawn(function()
        if GrandfatherTime then
            GrandfatherTime()
        else
            game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.Q, false, game)
        end
    end)
end)

